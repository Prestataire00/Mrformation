# ──────────────────────────────────────────────
# Supabase
# ──────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ──────────────────────────────────────────────
# OpenAI (génération de cours e-learning)
# ──────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ──────────────────────────────────────────────
# Email — Resend
# ──────────────────────────────────────────────
RESEND_API_KEY=re_...

# ──────────────────────────────────────────────
# Gmail OAuth2 (envoi d'emails via compte formateur)
# ──────────────────────────────────────────────
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/gmail/callback
GMAIL_TOKEN_ENCRYPTION_KEY=your-32-char-hex-key

# ──────────────────────────────────────────────
# Recherche entreprise
# ──────────────────────────────────────────────
PAPPERS_API_KEY=your-pappers-key
INFOGREFFE_API_KEY=your-infogreffe-key

# ──────────────────────────────────────────────
# Gamma (présentations e-learning)
# ──────────────────────────────────────────────
GAMMA_API_KEY=your-gamma-key

# ──────────────────────────────────────────────
# Application
# ──────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ──────────────────────────────────────────────
# Cron / Scheduled Functions
# ──────────────────────────────────────────────
# Générer avec : openssl rand -hex 32
# À ajouter aussi dans Netlify Dashboard → Site configuration → Environment variables
CRON_SECRET=your-secret-here
